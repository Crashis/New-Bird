# Firebase web app config — template only, no real values here.
# Copy to `.env` and fill in from Firebase Console > Project settings > Your apps.
#
# NOTE: This project is currently a static (no-bundler) site, so these env vars
# are NOT read at runtime by the browser. They serve as documentation and as a
# ready template if/when a bundler (e.g. Vite) is added later.
# For the running app, use `src/firebase.config.local.js` instead — see README.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
