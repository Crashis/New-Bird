rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{uid} {
      allow read: if true;

      allow create: if isSignedInOwner(uid)
        && hasAllowedFields()
        && hasValidLeaderboardData()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isSignedInOwner(uid)
        && resource.data.uid == request.auth.uid
        && hasAllowedFields()
        && hasValidLeaderboardData()
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.bestScore >= resource.data.bestScore;

      allow delete: if false;
    }

    function isSignedInOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function hasAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'displayName',
        'bestScore',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasValidLeaderboardData() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 20
        && request.resource.data.bestScore is number
        && request.resource.data.bestScore >= 0
        && request.resource.data.bestScore <= 100000;
    }

    match /users/{uid} {
      allow read: if isSignedInOwner(uid);

      allow create: if isSignedInOwner(uid)
        && hasUserAllowedFields()
        && hasValidUserData()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isSignedInOwner(uid)
        && resource.data.uid == request.auth.uid
        && hasUserAllowedFields()
        && hasValidUserData()
        && request.resource.data.updatedAt is timestamp;

      allow delete: if false;
    }

    function hasUserAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'displayName',
        'cloudSaveVersion',
        'hasCloudSave',
        'createdAt',
        'updatedAt',
        'progress'
      ]);
    }

    // ── Multiplayer lobby (Fáze 1) ──────────────────────────────
    // Lobby identifikujeme 6znakovým kódem. Číst a zapisovat smí pouze
    // přihlášený uživatel, který je hostem nebo guestem (nebo se právě
    // chystá stát guestem v rámci transakce).
    match /lobbies/{code} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.code == code
        && request.resource.data.status == 'waiting';

      // Update povolíme jen účastníkům lobby. Při guest-join je guestId v
      // existujícím dokumentu ještě null – proto kontrolujeme i variantu
      // "stávám se právě guestem".
      allow update: if request.auth != null && (
        resource.data.hostId == request.auth.uid
        || resource.data.guestId == request.auth.uid
        || (resource.data.guestId == null
            && request.resource.data.guestId == request.auth.uid)
      );

      // Mazat smí jen host.
      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    function hasValidUserData() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 20
        && request.resource.data.cloudSaveVersion is number
        && request.resource.data.hasCloudSave is bool
        && request.resource.data.progress is map
        && (
          !('bestScore' in request.resource.data.progress)
          || (request.resource.data.progress.bestScore is number
              && request.resource.data.progress.bestScore >= 0
              && request.resource.data.progress.bestScore <= 100000)
        )
        && (
          !('yang' in request.resource.data.progress)
          || (request.resource.data.progress.yang is number
              && request.resource.data.progress.yang >= 0
              && request.resource.data.progress.yang <= 10000000)
        )
        && (
          !('wallets' in request.resource.data.progress)
          || (request.resource.data.progress.wallets is number
              && request.resource.data.progress.wallets >= 0
              && request.resource.data.progress.wallets <= 1000000)
        )
        && (
          !('dragonCoins' in request.resource.data.progress)
          || (request.resource.data.progress.dragonCoins is number
              && request.resource.data.progress.dragonCoins >= 0
              && request.resource.data.progress.dragonCoins <= 1000000)
        );
    }
  }
}
